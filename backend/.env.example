# FreelanceRadar Scraper — Environment Variables

# Firebase service-account JSON. اختر واحدة فقط:
#   (أ) ضع المسار للملف:
#       FIREBASE_CREDENTIALS_PATH=./service-account.json
#   (ب) أو ألصق محتوى JSON كاملاً (سطر واحد):
#       FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}
FIREBASE_CREDENTIALS_PATH=
FIREBASE_CREDENTIALS_JSON=

# (اختياري) مفتاح Freelancer.com — مجاني من:
# https://developers.freelancer.com/
FREELANCER_API_KEY=

# Filtering
MIN_RELEVANCE_SCORE=0.3
MAX_JOB_AGE_DAYS=30

# Scraping behavior
REQUEST_DELAY_MIN=2
REQUEST_DELAY_MAX=5
